{
  "expo": {
    "name": "Code Quest",
    "slug": "code-quest",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "codequest",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080A0F",
    "splash": {
      "backgroundColor": "#07111f",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.leandrotoledo.codequest",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.leandrotoledo.codequest",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-asset"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
