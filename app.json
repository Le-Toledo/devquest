{
  "expo": {
    "icon": "./assets/Designer.png",
    "name": "Code Quest",
    "slug": "code-quest",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "codequest",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080A0F",
    "splash": {
      "backgroundColor": "#07111f",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.leandrotoledo.codequest",
      "buildNumber": "2"
    },
    "android": {
      "package": "com.leandrotoledo.codequest",
      "versionCode": 2
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-asset"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ded9603b-4003-4932-89e8-74972db304aa"
      }
    }
  }
}
