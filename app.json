{
  "expo": {
    "name": "CodeQuest Academy",
    "slug": "codequest-academy",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "codequestacademy",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#07111f",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.codequest.academy"
    },
    "android": {
      "package": "com.codequest.academy"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
