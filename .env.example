# Public Expo variables. Never put service_role keys or private secrets here.
EXPO_PUBLIC_SUPABASE_URL=
# Use the Supabase anon public key or the newer publishable key (sb_publishable_...).
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Professor Byte AI uses the Supabase Edge Function `professor-byte-ai`.
